@model Library.Domain.FollowUp

@{
    ViewData["Title"] = "Create";
}

<h1>Create FollowUp</h1>

<h4>FollowUp</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="InspectionId" class="control-label"></label>
                <select asp-for="InspectionId" class="form-control" asp-items="ViewBag.InspectionId"></select>
                <span asp-validation-for="InspectionId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="DueDate" class="control-label"></label>
                <input asp-for="DueDate" class="form-control" />
                <span asp-validation-for="DueDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" class="form-control" id="statusDropdown" asp-items="Html.GetEnumSelectList<Library.Domain.FollowUpStatus>()"></select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="form-group" id="closedDateGroup">
                <label asp-for="ClosedDate" class="control-label"></label>
                <input asp-for="ClosedDate" class="form-control" id="ClosedDate" />
                <span asp-validation-for="ClosedDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        window.onload = function() {
            var statusDropdown = document.getElementById("statusDropdown");
            var closedGroup = document.getElementById("closedDateGroup");
            var closedInput = document.getElementById("ClosedDate");

            function toggleClosedDate() {
                // "1" corresponds to enum value Closed
                if (statusDropdown.value === "1") {
                    closedGroup.style.display = "block";
                } else {
                    closedGroup.style.display = "none";
                    closedInput.value = "";
                }
            }

            statusDropdown.addEventListener("change", toggleClosedDate);
            toggleClosedDate();
        };
    </script>
}