@model Library.Domain.FollowUp

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit FollowUp</h1>

<h4>FollowUp</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label asp-for="InspectionId" class="control-label"></label>
                <select asp-for="InspectionId" class="form-control" asp-items="ViewBag.InspectionId"></select>
                <span asp-validation-for="InspectionId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="DueDate" class="control-label"></label>
                <input asp-for="DueDate" class="form-control" />
                <span asp-validation-for="DueDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" class="form-control" id="statusDropdown" asp-items="Html.GetEnumSelectList<Library.Domain.FollowUpStatus>()"></select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="form-group" id="closedDateGroup">
                <label asp-for="ClosedDate" class="control-label"></label>
                <input asp-for="ClosedDate" class="form-control" id="ClosedDate" />
                <span asp-validation-for="ClosedDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function toggleClosedDate() {
            var status = document.getElementById("statusDropdown").value;
            var group = document.getElementById("closedDateGroup");

            // 1 = Closed in the enum
            if (status === "1") {
                group.style.display = "block";
            } else {
                group.style.display = "none";
                document.getElementById("ClosedDate").value = "";
            }
        }

        document.getElementById("statusDropdown").addEventListener("change", toggleClosedDate);

        // call on page load to respect the model value
        toggleClosedDate();
    </script>
}